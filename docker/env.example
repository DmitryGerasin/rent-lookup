NODE_ENV=production

# Production IP check: `true` when nginx and app are in Docker (peer IP is private bridge). `false` when nginx on same host uses 127.0.0.1 to Node.
APP_BEHIND_DOCKER_PROXY='true'

# Public site host (no scheme). Used by the app and by nginx template + Let's Encrypt live/ dir name.
HOSTNAME='website.com'

# Port the Node app listens on inside Docker (nginx upstream must match).
NODE_PORT='3000'

# Hostname nginx uses to reach the Node container (Compose *service* name on the internal network, usually `app`).
NGINX_APP_HOST='app'

# Mysql (MYSQL_USER + MYSQL_PASSWORD both required by the mysql image to create the app user)
MYSQL_HOST='mysql'
MYSQL_DATABASE='realestate'
MYSQL_ROOT_PASSWORD=''
MYSQL_USER='real-estate-app'
MYSQL_PASSWORD=''

# expressjs
EXPRESS_SESSION_SECRET=''
EXPRESS_SESSION_KEY='sid'

# Security
CSRF_SECRET=''

# API Keys
GEOCODIO_API_KEY=''
RECAPTCHA_SITE_KEY=''
RECAPTCHA_SECRET_KEY=''
