NODE_ENV=production

# Public site host (no scheme). Used by the app and by nginx template + Let's Encrypt live/ dir name.
HOSTNAME='website.com'

# Port the Node app listens on inside Docker (nginx upstream must match).
NODE_PORT='3000'

# Mysql (MYSQL_USER + MYSQL_PASSWORD both required by the mysql image to create the app user)
MYSQL_HOST='mysql'
MYSQL_DATABASE='realestate'
MYSQL_ROOT_PASSWORD=''
MYSQL_USER='real-estate-app'
MYSQL_PASSWORD=''

# expressjs
EXPRESS_SESSION_SECRET=''
EXPRESS_SESSION_KEY='sid'

# Security
CSRF_SECRET=''

# API Keys
GEOCODIO_API_KEY=''
RECAPTCHA_SITE_KEY=''
RECAPTCHA_SECRET_KEY=''
