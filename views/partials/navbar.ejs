<%#
  Main Navbar Partial
  
  Includes: dashboard links, logo, user dropdown (profile, time, InvoiceNow, admin, logout)
  
  Required: current (string indicating current page, for highlighting)
  Expected: firstName, lastName, user, isAdmin
%>
<%
const userName = ((typeof firstName !== 'undefined' ? firstName : '') + ' ' + (typeof lastName !== 'undefined' ? lastName : '')).trim() || 'Utilisateur'
%>

<nav class="navbar navbar-expand-lg navbar-light bg-light">
   <div class="container-fluid">
   
      <div>
         <ul class="nav nav-tabs flex-row">
            <% if(current === 'dashboard') { %>
               <a href="/file/new" class="btn btn-outline-success">
                  Nouveau dossier
                  <%- include(`../icons/add.svg`) %>
               </a>
            <% } else { %>
               <li class="nav-item">
                  <a class="nav-link <%= current === 'dashboard' ? 'active' : '' %>" href="/dashboard">
                     Dashboard
                  </a>
               </li>
            <% } %>
            <li class="nav-item">
               <a class="nav-link <%= current === 'all' ? 'active' : '' %>" href="/dashboard/all">
                  Aperçu des dossiers
               </a>
            </li>
         </ul>
      </div>

      <%- include('./logo') %>

      <div>
         <ul class="nav nav-tabs flex-row align-items-center">
            <%# User Dropdown %>
            <li class="nav-item dropdown">
               <a 
                  class="nav-link dropdown-toggle" 
                  href="#" 
                  id="userDropdown" 
                  role="button" 
                  data-bs-toggle="dropdown" 
                  aria-expanded="false"
               >
                  <%- include(`../icons/profile.svg`) %>
                  <%= userName %>
               </a>
               <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                  <li>
                     <a class="dropdown-item <%= current === 'dashboard' ? 'active' : '' %>" href="/dashboard">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-house me-2" viewBox="0 0 16 16">
                           <path d="M8.707 1.5a1 1 0 0 0-1.414 0L.646 8.146a.5.5 0 0 0 .708.708L2 8.207V13.5A1.5 1.5 0 0 0 3.5 15h9a1.5 1.5 0 0 0 1.5-1.5V8.207l.646.647a.5.5 0 0 0 .708-.708L13 5.793V2.5a.5.5 0 0 0-.5-.5h-1a.5.5 0 0 0-.5.5v1.293z"/>
                        </svg>
                        Dashboard
                     </a>
                  </li>
                  <li>
                     <a class="dropdown-item <%= current === 'time' ? 'active' : '' %>" href="/time">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-clock me-2" viewBox="0 0 16 16">
                           <path d="M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71z"/>
                           <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16m7-8A7 7 0 1 1 1 8a7 7 0 0 1 14 0"/>
                        </svg>
                        Heures
                     </a>
                  </li>
                  <li>
                     <a class="dropdown-item <%= current === 'rtbc' ? 'active' : '' %>" href="/dashboard/rtbc">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-check2-square me-2" viewBox="0 0 16 16">
                           <path d="M3 14.5A1.5 1.5 0 0 1 1.5 13V3A1.5 1.5 0 0 1 3 1.5h8a.5.5 0 0 1 0 1H3a.5.5 0 0 0-.5.5v10a.5.5 0 0 0 .5.5h10a.5.5 0 0 0 .5-.5V8a.5.5 0 0 1 1 0v5a1.5 1.5 0 0 1-1.5 1.5H3z"/>
                           <path d="m8.354 10.354 7-7a.5.5 0 0 0-.708-.708L8 9.293 5.354 6.646a.5.5 0 1 0-.708.708l3 3a.5.5 0 0 0 .708 0z"/>
                        </svg>
                        Prêt à fermer
                     </a>
                  </li>
                  <li><hr class="dropdown-divider"></li>
                  <li><h6 class="dropdown-header">Créer</h6></li>
                  <li>
                     <a class="dropdown-item" href="/file/new">
                        <span class="me-2"><%- include(`../icons/add.svg`) %></span>
                        Nouveau dossier
                     </a>
                  </li>
                  <% if (isAdmin) { %>
                  <li><hr class="dropdown-divider"></li>
                  <li><h6 class="dropdown-header">Fidéicommis</h6></li>
                  <li>
                     <a class="dropdown-item" href="/trust/monthlyReport" target="_blank">
                        Rapport mensuel
                     </a>
                  </li>
                  <li>
                     <a class="dropdown-item" href="/trust/annualReport" target="_blank">
                        Rapport annuel
                     </a>
                  </li>
                  <li>
                     <a class="dropdown-item" href="/trust/transactionSummary" target="_blank">
                        Toutes les transactions
                     </a>
                  </li>
                  <li><hr class="dropdown-divider"></li>
                  <li>
                     <a class="dropdown-item <%= current === 'invoice-now' ? 'active' : '' %>" href="/admin/invoice-now">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-receipt me-2" viewBox="0 0 16 16">
                           <path d="M1.92.506a.5.5 0 0 1 .434.14L3 1.293l.646-.647a.5.5 0 0 1 .708 0L5 1.293l.646-.647a.5.5 0 0 1 .708 0L7 1.293l.646-.647a.5.5 0 0 1 .708 0L9 1.293l.646-.647a.5.5 0 0 1 .708 0l.646.647.646-.647a.5.5 0 0 1 .708 0l.646.647.646-.647a.5.5 0 0 1 .801.13l.5 1A.5.5 0 0 1 15 2v12a.5.5 0 0 1-.053.224l-.5 1a.5.5 0 0 1-.8.13L13 14.707l-.646.647a.5.5 0 0 1-.708 0L11 14.707l-.646.647a.5.5 0 0 1-.708 0L9 14.707l-.646.647a.5.5 0 0 1-.708 0L7 14.707l-.646.647a.5.5 0 0 1-.708 0L5 14.707l-.646.647a.5.5 0 0 1-.708 0L3 14.707l-.646.647a.5.5 0 0 1-.801-.13l-.5-1A.5.5 0 0 1 1 14V2a.5.5 0 0 1 .053-.224l.5-1a.5.5 0 0 1 .367-.27zM2 4.15V13h12V4.15L12.5 2 12 3.5 11.5 2l-.5 1.5-.5-1.5-.5 1.5-.5-1.5-.5 1.5-.5-1.5-.5 1.5-.5-1.5L2 4.15Z"/>
                        </svg>
                        À facturer maintenant
                     </a>
                  </li>
                  <li>
                     <a class="dropdown-item <%= current === 'admin' ? 'active' : '' %>" href="/admin">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-gear me-2" viewBox="0 0 16 16">
                           <path d="M8 4.754a3.246 3.246 0 1 0 0 6.492 3.246 3.246 0 0 0 0-6.492M5.754 8a2.246 2.246 0 1 1 4.492 0 2.246 2.246 0 0 1-4.492 0"/>
                           <path d="M9.796 1.343c-.527-1.79-3.065-1.79-3.592 0l-.094.319a.873.873 0 0 1-1.255.52l-.292-.16c-1.64-.892-3.433.902-2.54 2.541l.159.292a.873.873 0 0 1-.52 1.255l-.319.094c-1.79.527-1.79 3.065 0 3.592l.319.094a.873.873 0 0 1 .52 1.255l-.16.292c-.892 1.64.901 3.434 2.541 2.54l.292-.159a.873.873 0 0 1 1.255.52l.094.319c.527 1.79 3.065 1.79 3.592 0l.094-.319a.873.873 0 0 1 1.255-.52l.292.16c1.64.893 3.434-.902 2.54-2.541l-.159-.292a.873.873 0 0 1 .52-1.255l.319-.094c1.79-.527 1.79-3.065 0-3.592l-.319-.094a.873.873 0 0 1-.52-1.255l.16-.292c.893-1.64-.902-3.433-2.541-2.54l-.292.159a.873.873 0 0 1-1.255-.52zm-2.633.283c.246-.835 1.428-.835 1.674 0l.094.319a1.873 1.873 0 0 0 2.693 1.115l.291-.16c.764-.415 1.6.42 1.184 1.185l-.159.292a1.873 1.873 0 0 0 1.116 2.692l.318.094c.835.246.835 1.428 0 1.674l-.319.094a1.873 1.873 0 0 0-1.115 2.693l.16.291c.415.764-.42 1.6-1.185 1.184l-.291-.159a1.873 1.873 0 0 0-2.693 1.116l-.094.318c-.246.835-1.428.835-1.674 0l-.094-.319a1.873 1.873 0 0 0-2.692-1.115l-.292.16c-.764.415-1.6-.42-1.184-1.185l.159-.291A1.873 1.873 0 0 0 1.945 8.93l-.319-.094c-.835-.246-.835-1.428 0-1.674l.319-.094A1.873 1.873 0 0 0 3.06 4.377l-.16-.292c-.415-.764.42-1.6 1.185-1.184l.292.159a1.873 1.873 0 0 0 2.692-1.115z"/>
                        </svg>
                        Panneau d’administration
                     </a>
                  </li>
                  <% } %>
                  <li><hr class="dropdown-divider"></li>
                  <li>
                     <a class="dropdown-item <%= current === 'profile' ? 'active' : '' %>" href="/profile">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-person me-2" viewBox="0 0 16 16">
                           <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6m2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0m4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4m-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.289 10 8 10s-3.516.68-4.168 1.332c-.678.678-.83 1.418-.832 1.664z"/>
                        </svg>
                        Profil
                     </a>
                  </li>
                  <li>
                     <button
                        type="button"
                        id="logoutBtn"
                        class="btn btn-link text-danger text-start dropdown-item"
                     >
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-box-arrow-right me-2" viewBox="0 0 16 16">
                           <path fill-rule="evenodd" d="M10 12.5a.5.5 0 0 1-.5.5h-8a.5.5 0 0 1-.5-.5v-9a.5.5 0 0 1 .5-.5h8a.5.5 0 0 1 .5.5v2a.5.5 0 0 0 1 0v-2A1.5 1.5 0 0 0 9.5 2h-8A1.5 1.5 0 0 0 0 3.5v9A1.5 1.5 0 0 0 1.5 14h8a1.5 1.5 0 0 0 1.5-1.5v-2a.5.5 0 0 0-1 0z"/>
                           <path fill-rule="evenodd" d="M15.854 8.354a.5.5 0 0 0 0-.708l-3-3a.5.5 0 0 0-.708.708L14.293 7.5H5.5a.5.5 0 0 0 0 1h8.793l-2.147 2.146a.5.5 0 0 0 .708.708z"/>
                        </svg>
                        Se déconnecter
                     </button>
                  </li>
               </ul>
            </li>
         </ul>
      </div>
      
   </div>
</nav>

