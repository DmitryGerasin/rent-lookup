<%# Login form - no action, submission handled by login.bundle.js %>
<form id="login-form">
   <div class="form-section">
      <!-- <h5 class="form-section-title">Identifiants</h5> -->
      <div class="row g-2">
         <div class="col-12 col-md-6 form-floating">
            <input
               type="email" id="email" name="email"
               class="form-control border" placeholder="."
               autocomplete="email"
            >
            <label for="email">Courriel</label>
         </div>
         <div class="col-12 col-md-6 form-floating">
            <input
               type="password" id="password" name="password"
               class="form-control border" placeholder="."
               autocomplete="current-password"
            >
            <label for="password">Mot de passe</label>
         </div>
      </div>
   </div>

   <%- include('../partials/recaptcha.ejs', { captchaSiteKey }) %>

   <button type="button" id="loginSubmit" class="btn btn-primary btn-lg w-100">Connexion</button>

   <p class="login-legal-notice mb-0 mt-3 text-center text-muted">
      <small>Accès réservé aux comptes autorisés.</small>
   </p>
</form>
